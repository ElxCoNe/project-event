@model EventProject.Models.Event

@{
    ViewData["Title"] = "Editar Torneo";
}

<div class="row">
    <div class="col s12">
        <h4 class="white-text">
            <i class="material-icons">edit</i> Editar Torneo
        </h4>
    </div>
</div>

<div class="row">
    <div class="col s12 m8">
        <div class="card grey darken-3">
            <div class="card-content">
                <form asp-action="Edit" asp-controller="Event" method="post">
                    
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="Status" />

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix white-text">sports_esports</i>
                            <input asp-for="Name" type="text" class="white-text" required />
                            <label asp-for="Name" class="white-text active">Nombre del Torneo</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix white-text">description</i>
                            <textarea asp-for="Description" class="materialize-textarea white-text" required></textarea>
                            <label asp-for="Description" class="white-text active">Descripción</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix white-text">event</i>
                            <input asp-for="Date" type="date" class="white-text" required />
                            <label asp-for="Date" class="white-text active">Fecha</label>
                        </div>
                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix white-text">location_on</i>
                            <input asp-for="Location" type="text" class="white-text" required />
                            <label asp-for="Location" class="white-text active">Ubicación</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix white-text">category</i>
                            <select asp-for="Category" required>
                                <option value="" disabled>Selecciona categoría</option>
                                @foreach (var cat in new[] { "FPS", "MOBA", "Fighting", "Sports", "RTS", "Battle Royale" })
                                {
                                    if (Model.Category == cat)
                                    {
                                        <option value="@cat" selected>@cat</option>
                                    }
                                    else
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                }
                            </select>
                            <label class="white-text active">Categoría</label>
                        </div>
                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix white-text">people</i>
                            <input asp-for="Capacity" type="number" min="1" class="white-text" required />
                            <label asp-for="Capacity" class="white-text active">Capacidad</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix white-text">image</i>
                            <input asp-for="ImageURL" type="url" class="white-text" />
                            <label asp-for="ImageURL" class="white-text active">URL de imagen (opcional)</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col s12">
                            <button type="submit" class="btn blue waves-effect waves-light">
                                <i class="material-icons left">save</i> Actualizar Torneo
                            </button>
                            <a asp-action="Index" class="btn grey waves-effect waves-light">
                                <i class="material-icons left">arrow_back</i> Cancelar
                            </a>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var selects = document.querySelectorAll('select');
            M.FormSelect.init(selects);
        });
    </script>
}